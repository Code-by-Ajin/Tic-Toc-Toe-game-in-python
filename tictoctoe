# --- Animated Background ---
class Particle:
    def __init__(self):
        self.x = random.randint(0, WIDTH)
        self.y = random.randint(0, HEIGHT)
        self.r = random.randint(2, 6)
        self.dx = random.uniform(-1, 1)
        self.dy = random.uniform(-1, 1)
        # Setup for dynamic particle colors
        self.color = [float(random.randint(100, 255)) for _ in range(3)]
        self.target_color = [float(random.randint(100, 255)) for _ in range(3)]

    def move(self):
        self.x += self.dx
        self.y += self.dy
        if self.x < 0 or self.x > WIDTH: self.dx *= -1
        if self.y < 0 or self.y > HEIGHT: self.dy *= -1
        
        # Smoothly shift the particle colors
        for i in range(3):
            if self.color[i] < self.target_color[i]:
                self.color[i] += 0.5
            elif self.color[i] > self.target_color[i]:
                self.color[i] -= 0.5
            
            # Pick a new color target when reached
            if abs(self.color[i] - self.target_color[i]) <= 0.5:
                self.target_color[i] = float(random.randint(100, 255))

    def draw(self, surface):
        c = (int(self.color[0]), int(self.color[1]), int(self.color[2]))
        pygame.draw.circle(surface, c, (int(self.x), int(self.y)), self.r)

particles = [Particle() for _ in range(70)]

# --- UI Components ---
class Button:
    def __init__(self, x, y, w, h, text, font, action=None, color=BTN_COLOR):
        self.rect = pygame.Rect(x, y, w, h)
        self.text = text
        self.font = font
        self.action = action
        self.color = color

    def draw(self, surface):
        mouse_pos = pygame.mouse.get_pos()
        is_hover = self.rect.collidepoint(mouse_pos)
        color = BTN_HOVER if is_hover else self.color
        
        pygame.draw.rect(surface, color, self.rect, border_radius=15)
        pygame.draw.rect(surface, TEXT_COLOR, self.rect, 2, border_radius=15)
        
        txt_surf = self.font.render(self.text, True, TEXT_COLOR)
        txt_rect = txt_surf.get_rect(center=self.rect.center)
        surface.blit(txt_surf, txt_rect)

    def handle_event(self, event):
        if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:
            if self.rect.collidepoint(event.pos) and self.action:
                self.action()

# --- Game Logic Functions ---
def reset_board():
    global board, current_player, winner, round_starter
    board = [' '] * 9
    winner = None
    round_starter = 'O' if round_starter == 'X' else 'X'
    current_player = round_starter

def full_reset():
    global scores, round_starter
    scores = {'X': 0, 'O': 0}
    round_starter = 'O'
    reset_board()

def check_win(b, player):
    win_cond = [(0,1,2), (3,4,5), (6,7,8), (0,3,6), (1,4,7), (2,5,8), (0,4,8), (2,4,6)]
    return any(b[i] == b[j] == b[k] == player for i, j, k in win_cond)

def check_draw(b):
    return ' ' not in b

# --- AI Logic ---
def get_empty_spots(b):
    return [i for i, spot in enumerate(b) if spot == ' ']

def ai_move():
    global board
    empty = get_empty_spots(board)
    if not empty: return

    if difficulty == "EASY":
        move = random.choice(empty)
    elif difficulty == "MEDIUM":
        move = -1
        for i in empty: # Try Win
            b_copy = board[:]
            b_copy[i] = 'O'
            if check_win(b_copy, 'O'): move = i; break
        if move == -1: # Try Block
            for i in empty:
                b_copy = board[:]
                b_copy[i] = 'X'
                if check_win(b_copy, 'X'): move = i; break
        if move == -1: move = random.choice(empty) # Random
    else: # HARD
        best_score = -math.inf
        move = random.choice(empty)
        for i in empty:
            board[i] = 'O'
            score = minimax(board, 0, False)
            board[i] = ' '
            if score > best_score:
                best_score = score
                move = i
    
    board[move] = 'O'
    finalize_turn()

def minimax(b, depth, is_maximizing):
    if check_win(b, 'O'): return 10 - depth
    if check_win(b, 'X'): return depth - 10
    if check_draw(b): return 0

    if is_maximizing:
        best = -math.inf
        for i in get_empty_spots(b):
            b[i] = 'O'
            best = max(best, minimax(b, depth + 1, False))
            b[i] = ' '
        return best
    else:
        best = math.inf
        for i in get_empty_spots(b):
            b[i] = 'X'
            best = min(best, minimax(b, depth + 1, True))
            b[i] = ' '
        return best

def finalize_turn():
    global current_player, winner, scores, state
    if check_win(board, current_player):
        scores[current_player] += 1
        if scores[current_player] >= max_rounds:
            state = "GAME_OVER"
        else:
            # Show the winning move before resetting
            draw_playing_state()
            pygame.display.flip()
            pygame.time.delay(1000) # Wait 1 second so players can see the move
            reset_board()
    elif check_draw(board):
        # Show the final draw move before resetting
        draw_playing_state()
        pygame.display.flip()
        pygame.time.delay(1000)
        reset_board()
    else:
        current_player = 'O' if current_player == 'X' else 'X'

