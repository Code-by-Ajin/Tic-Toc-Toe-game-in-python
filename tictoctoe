# --- Draw Functions ---
def draw_bg():
    global current_bg_idx, target_bg_idx, bg_timer_start
    
    now = pygame.time.get_ticks()
    progress = (now - bg_timer_start) / BG_TRANSITION_TIME
    
    if progress >= 1.0:
        current_bg_idx = target_bg_idx
        target_bg_idx = random.randint(0, 9)
        bg_timer_start = now
        progress = 0.0

    c1 = BG_COLORS[current_bg_idx]
    c2 = BG_COLORS[target_bg_idx]
    
    r = int(c1[0] + (c2[0] - c1[0]) * progress)
    g = int(c1[1] + (c2[1] - c1[1]) * progress)
    b = int(c1[2] + (c2[2] - c1[2]) * progress)
    
    screen.fill((r, g, b))
    
    for p in particles:
        p.move()
        p.draw(screen)

def draw_grid():
    grid_size = int(HEIGHT * 0.5)
    start_x, start_y = WIDTH//2 - grid_size//2, HEIGHT//2 - grid_size//2
    cell = grid_size // 3

    pygame.draw.line(screen, GRID_COLOR, (start_x + cell, start_y), (start_x + cell, start_y + grid_size), 5)
    pygame.draw.line(screen, GRID_COLOR, (start_x + cell*2, start_y), (start_x + cell*2, start_y + grid_size), 5)
    pygame.draw.line(screen, GRID_COLOR, (start_x, start_y + cell), (start_x + grid_size, start_y + cell), 5)
    pygame.draw.line(screen, GRID_COLOR, (start_x, start_y + cell*2), (start_x + grid_size, start_y + cell*2), 5)

    for i, mark in enumerate(board):
        x = start_x + (i % 3) * cell + cell // 2
        y = start_y + (i // 3) * cell + cell // 2
        if mark == 'X':
            txt = font_large.render("X", True, X_COLOR)
            screen.blit(txt, txt.get_rect(center=(x, y)))
        elif mark == 'O':
            txt = font_large.render("O", True, O_COLOR)
            screen.blit(txt, txt.get_rect(center=(x, y)))

def draw_scoreboard():
    if game_mode == "SINGLE":
        p1_text = f"Human (X): {scores['X']}"
        p2_text = f"Computer (O): {scores['O']}"
    else:
        p1_text = f"Player 1 (X): {scores['X']}"
        p2_text = f"Player 2 (O): {scores['O']}"

    target_text = f"First to {max_rounds} wins!"

    t1 = font_med.render(p1_text, True, X_COLOR)
    t2 = font_med.render(p2_text, True, O_COLOR)
    t3 = font_small.render(target_text, True, (200, 200, 200))

    screen.blit(t1, (WIDTH//2 - int(WIDTH*0.3), HEIGHT - int(HEIGHT*0.15)))
    screen.blit(t2, (WIDTH//2 + int(WIDTH*0.05), HEIGHT - int(HEIGHT*0.15)))
    screen.blit(t3, (WIDTH//2 - t3.get_width()//2, HEIGHT - int(HEIGHT*0.07)))

def draw_title(text, y=HEIGHT*0.15):
    title = font_large.render(text, True, TEXT_COLOR)
    screen.blit(title, title.get_rect(center=(WIDTH//2, int(y))))

# Extracted drawing function for the active game view
def draw_playing_state():
    draw_bg()
    btn_back.draw(screen)
    btn_pause.draw(screen)
    draw_grid()
    draw_scoreboard()
    turn_txt = f"Turn: {'Player 1 (X)' if current_player=='X' else 'Player 2 (O)' if game_mode=='MULTI' else 'Computer (O)'}"
    screen.blit(font_small.render(turn_txt, True, TEXT_COLOR), (WIDTH//2 - int(WIDTH*0.08), 20))


# --- Main Loop ---
ai_timer = 0
running = True
while running:
    draw_bg()
    btn_music.text = "Music: ON" if music_on else "Music: OFF"

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
            
        if event.type == pygame.KEYDOWN and event.key == pygame.K_ESCAPE:
            running = False
            
        if event.type == MUSIC_END_EVENT:
            play_random_music()

        if state == "MAIN_MENU":
            btn_start.handle_event(event); btn_quit.handle_event(event); btn_music.handle_event(event)
        elif state == "MODE_SELECT":
            btn_single.handle_event(event); btn_multi.handle_event(event); btn_back.handle_event(event)
        elif state == "DIFF_SELECT":
            btn_easy.handle_event(event); btn_med.handle_event(event); btn_hard.handle_event(event); btn_back.handle_event(event)
        elif state == "ROUND_SELECT":
            btn_r5.handle_event(event); btn_r10.handle_event(event); btn_r15.handle_event(event); btn_r20.handle_event(event); btn_back.handle_event(event)
        elif state == "PLAYING":
            btn_back.handle_event(event); btn_pause.handle_event(event)
            
            if event.type == pygame.MOUSEBUTTONDOWN:
                if current_player == 'X' or game_mode == "MULTI":
                    grid_size = int(HEIGHT * 0.5)
                    start_x, start_y = WIDTH//2 - grid_size//2, HEIGHT//2 - grid_size//2
                    mx, my = event.pos
                    if start_x < mx < start_x + grid_size and start_y < my < start_y + grid_size:
                        col = int((mx - start_x) // (grid_size / 3))
                        row = int((my - start_y) // (grid_size / 3))
                        idx = row * 3 + col
                        if board[idx] == ' ':
                            board[idx] = current_player
                            finalize_turn()
                            if game_mode == "SINGLE" and state == "PLAYING":
                                ai_timer = pygame.time.get_ticks()

        elif state == "PAUSED":
            btn_resume.handle_event(event); btn_restart.handle_event(event); btn_pquit.handle_event(event)
        elif state == "GAME_OVER":
            btn_replay.handle_event(event); btn_gmenu.handle_event(event)

    # --- State Rendering & Logic ---
    if state == "MAIN_MENU":
        draw_title("TIC TAC TOE")
        btn_start.draw(screen); btn_quit.draw(screen); btn_music.draw(screen)

    elif state == "MODE_SELECT":
        draw_title("Select Mode")
        btn_single.draw(screen); btn_multi.draw(screen); btn_back.draw(screen)

    elif state == "DIFF_SELECT":
        draw_title("Difficulty")
        btn_easy.draw(screen); btn_med.draw(screen); btn_hard.draw(screen); btn_back.draw(screen)

    elif state == "ROUND_SELECT":
        draw_title("Rounds to Win")
        btn_r5.draw(screen); btn_r10.draw(screen); btn_r15.draw(screen); btn_r20.draw(screen); btn_back.draw(screen)

    elif state == "PLAYING":
        draw_playing_state() # Using the new helper function

        # AI Turn trigger
        if game_mode == "SINGLE" and current_player == 'O':
            if pygame.time.get_ticks() - ai_timer > 600:
                ai_move()

    elif state == "PAUSED":
        draw_grid()
        overlay = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA)
        overlay.fill(POPUP_BG)
        screen.blit(overlay, (0,0))
        draw_title("PAUSED", HEIGHT * 0.2)
        btn_resume.draw(screen); btn_restart.draw(screen); btn_pquit.draw(screen)

    elif state == "GAME_OVER":
        draw_grid()
        overlay = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA)
        overlay.fill(POPUP_BG)
        screen.blit(overlay, (0,0))
        
        winner_name = "Player 1 (X)" if scores['X'] == max_rounds else "Player 2 (O)"
        if game_mode == "SINGLE":
            winner_name = "Human (X)" if scores['X'] == max_rounds else "Computer (O)"
            
        draw_title("CONGRATULATIONS!", HEIGHT * 0.3)
        w_txt = font_med.render(f"{winner_name} Won the Match!", True, (255,215,0))
        screen.blit(w_txt, w_txt.get_rect(center=(WIDTH//2, HEIGHT * 0.45)))
        
        btn_replay.draw(screen); btn_gmenu.draw(screen)

    pygame.display.flip()
    clock.tick(FPS)

pygame.quit()
sys.exit()